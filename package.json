{
  "name": "gost-catalog-site",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "node ./node_modules/vite/bin/vite.js build",
    "test": "node --test",
    "build:reg": "node ./node_modules/vite/bin/vite.js build",
    "build:pages": "node ./node_modules/vite/bin/vite.js build",
    "deploy:pack": "npm run build:reg && node scripts/create-deploy-archive.mjs",
    "deploy:ssh": "npm run build:reg && node scripts/deploy-reg-ssh.mjs",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "import:one": "node scripts/import-viewer.mjs",
    "import:all": "node scripts/import-viewer.mjs --all",
    "reindex": "node scripts/build-search-index.mjs",
    "canonical:rebuild": "node scripts/rebuild-canonical-docs.mjs",
    "canonical-public:rebuild": "node scripts/rebuild-v2-data.mjs",
    "curation:rebuild": "node scripts/rebuild-curation-data.mjs",
    "curation-workbench:rebuild": "node scripts/rebuild-curation-workbench.mjs",
    "v2:rebuild": "node scripts/rebuild-v2-data.mjs",
    "v2-search:rebuild": "node scripts/build-v2-search-index.mjs",
    "print:rebuild": "node scripts/rebuild-print-docs.mjs",
    "manifest:rebuild": "node scripts/rebuild-manifest.mjs",
    "validate:viewers": "node scripts/validate-viewer.mjs"
  },
  "devDependencies": {
    "vite": "^6.3.5"
  }
}
